{
  "name": "hexagonal-modular-monolith",
  "version": "1.0.0",
  "description": "Implementasi Hexagonal/Clean Architecture dengan Modular Monolith menggunakan TypeScript",
  "main": "dist/bootstrap/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node -r tsconfig-paths/register dist/bootstrap/main.js",
    "dev": "ts-node -r tsconfig-paths/register src/bootstrap/main.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "hexagonal-architecture",
    "clean-architecture",
    "modular-monolith",
    "typescript",
    "ddd"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.8.2",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.2.2"
  }
}
